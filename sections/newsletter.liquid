{% comment %}
  La Camille - Premium Newsletter Signup
  Animated email capture with validation
{% endcomment %}

<div class="newsletter-section" id="newsletter-{{ section.id }}">
  <div class="newsletter-wrapper">
    <div class="newsletter-content">
      <div class="newsletter-visual">
        {% if section.settings.show_icon %}
          <div class="newsletter-icon">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </div>
        {% endif %}

        {% if section.settings.image != blank %}
          <div class="newsletter-image">
            <img src="{{ section.settings.image | img_url: '600x' }}"
                 alt="{{ section.settings.image.alt | default: 'Newsletter' }}"
                 loading="lazy">
          </div>
        {% endif %}
      </div>

      <div class="newsletter-form-wrapper">
        <h2 class="newsletter-title">{{ section.settings.title }}</h2>
        {% if section.settings.subtitle != blank %}
          <p class="newsletter-subtitle">{{ section.settings.subtitle }}</p>
        {% endif %}

        {% form 'customer' %}
          <input type="hidden" name="contact[tags]" value="newsletter">

          <div class="newsletter-form">
            <div class="newsletter-input-group">
              <input type="email"
                     name="contact[email]"
                     id="email-{{ section.id }}"
                     class="newsletter-input"
                     placeholder="{{ section.settings.placeholder }}"
                     required
                     pattern="[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}$"
                     aria-label="Email address">

              <button type="submit" class="newsletter-button">
                <span class="button-text">{{ section.settings.button_text }}</span>
                <span class="button-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </span>
              </button>
            </div>

            <div class="newsletter-benefits">
              {% if section.settings.benefit_1 != blank %}
                <div class="benefit-item">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                  <span>{{ section.settings.benefit_1 }}</span>
                </div>
              {% endif %}
              {% if section.settings.benefit_2 != blank %}
                <div class="benefit-item">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                  <span>{{ section.settings.benefit_2 }}</span>
                </div>
              {% endif %}
              {% if section.settings.benefit_3 != blank %}
                <div class="benefit-item">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                  <span>{{ section.settings.benefit_3 }}</span>
                </div>
              {% endif %}
            </div>
          </div>

          {% if form.posted_successfully? %}
            <div class="newsletter-success">
              <div class="success-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                  <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
              </div>
              <p>{{ section.settings.success_message }}</p>
            </div>
          {% endif %}

          {% if form.errors %}
            <div class="newsletter-error">
              <p>Please enter a valid email address.</p>
            </div>
          {% endif %}
        {% endform %}

        {% if section.settings.privacy_note != blank %}
          <p class="newsletter-privacy">{{ section.settings.privacy_note }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const newsletterSection = document.getElementById('newsletter-{{ section.id }}');
    if (!newsletterSection) return;

    // Newsletter Form Animation
    class NewsletterForm {
      constructor(section) {
        this.section = section;
        this.form = section.querySelector('form');
        this.input = section.querySelector('.newsletter-input');
        this.button = section.querySelector('.newsletter-button');
        this.successMessage = section.querySelector('.newsletter-success');
        this.errorMessage = section.querySelector('.newsletter-error');

        this.init();
      }

      init() {
        if (!this.form) return;

        this.setupAnimations();
        this.setupValidation();
        this.setupScrollAnimation();
      }

      setupAnimations() {
        if (!this.button) return;

        this.button.addEventListener('click', () => {
          if (this.input.checkValidity()) {
            this.button.classList.add('loading');
          }
        });
      }

      setupValidation() {
        if (!this.input) return;

        // Real-time validation
        this.input.addEventListener('input', () => {
          if (this.input.checkValidity()) {
            this.input.classList.remove('invalid');
            this.input.classList.add('valid');
          } else {
            this.input.classList.remove('valid');
            this.input.classList.add('invalid');
          }
        });

        this.input.addEventListener('blur', () => {
          if (this.input.value && !this.input.checkValidity()) {
            this.input.classList.add('invalid');
          }
        });
      }

      setupScrollAnimation() {
        const observerOptions = {
          root: null,
          rootMargin: '0px',
          threshold: 0.2
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              this.section.classList.add('animate-in');
            }
          });
        }, observerOptions);

        observer.observe(this.section);
      }
    }

    new NewsletterForm(newsletterSection);
  });
</script>

<style>
  .newsletter-section {
    padding: var(--spacing-xl) var(--spacing-md);
    background: var(--color-cream);
    position: relative;
    overflow: hidden;
  }

  .newsletter-section::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 600px;
    height: 600px;
    background: var(--color-blush);
    opacity: 0.1;
    border-radius: 50%;
    filter: blur(100px);
  }

  .newsletter-wrapper {
    max-width: 1200px;
    margin: 0 auto;
  }

  .newsletter-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .newsletter-section.animate-in .newsletter-content {
    opacity: 1;
    transform: translateY(0);
  }

  .newsletter-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .newsletter-icon {
    width: 120px;
    height: 120px;
    background: var(--color-white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    color: var(--color-champagne);
    animation: float 3s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  .newsletter-image {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  .newsletter-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .newsletter-form-wrapper {
    max-width: 500px;
  }

  .newsletter-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 400;
    color: var(--color-text);
    margin: 0 0 1rem 0;
    line-height: 1.2;
  }

  .newsletter-subtitle {
    font-size: 1.1rem;
    color: var(--color-text-light);
    margin: 0 0 2rem 0;
    line-height: 1.6;
  }

  .newsletter-form {
    position: relative;
  }

  .newsletter-input-group {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .newsletter-input {
    flex: 1;
    padding: 1rem 1.5rem;
    border: 2px solid var(--color-blush);
    border-radius: 8px;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    background: var(--color-white);
    transition: all 0.3s ease;
  }

  .newsletter-input:focus {
    outline: none;
    border-color: var(--color-champagne);
    box-shadow: 0 4px 12px rgba(212, 175, 55, 0.1);
  }

  .newsletter-input.valid {
    border-color: #27ae60;
  }

  .newsletter-input.invalid {
    border-color: #e74c3c;
  }

  .newsletter-button {
    padding: 1rem 2rem;
    background: var(--color-champagne);
    color: var(--color-white);
    border: none;
    border-radius: 8px;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .newsletter-button:hover {
    background: var(--color-text);
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.15);
  }

  .newsletter-button.loading {
    pointer-events: none;
    opacity: 0.8;
  }

  .newsletter-button.loading .button-text {
    opacity: 0;
  }

  .newsletter-button.loading .button-icon {
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .newsletter-benefits {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .benefit-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--color-text-light);
  }

  .benefit-item svg {
    color: var(--color-champagne);
    flex-shrink: 0;
  }

  .newsletter-success {
    text-align: center;
    padding: 2rem;
    background: var(--color-white);
    border-radius: 12px;
    animation: slideInUp 0.5s ease;
  }

  @keyframes slideInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .success-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 1.5rem;
    background: var(--color-champagne);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-white);
    animation: scaleIn 0.5s ease;
  }

  @keyframes scaleIn {
    from {
      transform: scale(0);
    }
    to {
      transform: scale(1);
    }
  }

  .newsletter-success p {
    font-size: 1.1rem;
    color: var(--color-text);
    margin: 0;
  }

  .newsletter-error {
    margin-top: 1rem;
    padding: 1rem;
    background: #fee;
    border: 1px solid #fcc;
    border-radius: 8px;
    color: #c33;
    text-align: center;
  }

  .newsletter-privacy {
    font-size: 0.85rem;
    color: var(--color-text-light);
    text-align: center;
    margin-top: 1.5rem;
    line-height: 1.5;
  }

  .newsletter-privacy a {
    color: var(--color-champagne);
    text-decoration: none;
  }

  .newsletter-privacy a:hover {
    text-decoration: underline;
  }

  @media (max-width: 968px) {
    .newsletter-content {
      grid-template-columns: 1fr;
      gap: 3rem;
      text-align: center;
    }

    .newsletter-input-group {
      flex-direction: column;
    }

    .newsletter-button {
      width: 100%;
      justify-content: center;
    }

    .newsletter-benefits {
      align-items: center;
    }
  }

  @media (max-width: 600px) {
    .newsletter-section {
      padding: var(--spacing-lg) var(--spacing-md);
    }

    .newsletter-icon {
      width: 100px;
      height: 100px;
    }

    .newsletter-title {
      font-size: 1.8rem;
    }
  }
</style>

{% schema %}
{
  "name": "Newsletter Signup",
  "tag": "section",
  "class": "section-newsletter",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show icon",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Featured image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Join the La Camille Family"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Subscribe for exclusive offers, new arrivals, and luxury lingerie tips."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you for subscribing! Check your email for a welcome gift."
    },
    {
      "type": "text",
      "id": "benefit_1",
      "label": "Benefit 1",
      "default": "15% off your first order"
    },
    {
      "type": "text",
      "id": "benefit_2",
      "label": "Benefit 2",
      "default": "Exclusive access to new collections"
    },
    {
      "type": "text",
      "id": "benefit_3",
      "label": "Benefit 3",
      "default": "VIP-only sales and promotions"
    },
    {
      "type": "text",
      "id": "privacy_note",
      "label": "Privacy note",
      "default": "By subscribing, you agree to our Privacy Policy and consent to receive updates."
    }
  ],
  "presets": [
    {
      "name": "Newsletter Signup",
      "category": "La Camille"
    }
  ]
}
{% endschema %}