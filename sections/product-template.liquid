{% schema %}
{
  "name": "Product Template",
  "tag": "section",
  "class": "product-template-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_sticky_info",
      "label": "Enable sticky product info",
      "default": true
    },
    {
      "type": "select",
      "id": "gallery_layout",
      "label": "Gallery layout",
      "options": [
        {
          "value": "thumbnail",
          "label": "Thumbnail"
        },
        {
          "value": "slider",
          "label": "Slider"
        }
      ],
      "default": "thumbnail"
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "Title",
      "limit": 1
    },
    {
      "type": "price",
      "name": "Price",
      "limit": 1
    },
    {
      "type": "variant_picker",
      "name": "Variant Picker",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "picker_type",
          "label": "Picker type",
          "options": [
            {
              "value": "button",
              "label": "Button"
            },
            {
              "value": "dropdown",
              "label": "Dropdown"
            }
          ],
          "default": "button"
        }
      ]
    },
    {
      "type": "quantity",
      "name": "Quantity",
      "limit": 1
    },
    {
      "type": "buy_buttons",
      "name": "Buy Buttons",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_dynamic_checkout",
          "label": "Show dynamic checkout buttons",
          "default": true
        }
      ]
    },
    {
      "type": "description",
      "name": "Description",
      "limit": 1
    },
    {
      "type": "accordion",
      "name": "Accordion",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Details"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Template",
      "blocks": [
        {
          "type": "title"
        },
        {
          "type": "price"
        },
        {
          "type": "variant_picker"
        },
        {
          "type": "quantity"
        },
        {
          "type": "buy_buttons"
        },
        {
          "type": "description"
        }
      ]
    }
  ]
}
{% endschema %}

{% style %}
  .product-template-section {
    padding: 4rem 2rem;
    background: var(--color-cream);
  }

  .product-container {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* Product Gallery */
  .product-gallery {
    position: sticky;
    top: 2rem;
  }

  .main-image-wrapper {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: 8px;
    margin-bottom: 1rem;
    background: var(--color-white);
  }

  .main-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .main-image:hover {
    transform: scale(1.05);
  }

  .thumbnail-nav {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .thumbnail {
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 4px;
    cursor: pointer;
    border: 2px solid transparent;
    transition: all 0.3s ease;
  }

  .thumbnail:hover,
  .thumbnail.active {
    border-color: var(--color-champagne);
    transform: translateY(-2px);
  }

  .thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Product Info */
  .product-info {
    padding: 2rem;
    background: var(--color-white);
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
  }

  .product-badges {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .badge {
    display: inline-block;
    padding: 0.4rem 0.8rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: 3px;
  }

  .badge-sale {
    background: var(--color-champagne);
    color: var(--color-white);
  }

  .badge-new {
    background: var(--color-blush);
    color: var(--color-text);
  }

  .product-title {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 300;
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  .product-vendor {
    font-size: 0.9rem;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 1rem;
  }

  .product-price-area {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-blush);
  }

  .product-price {
    font-size: 2rem;
    color: var(--color-champagne);
    font-weight: 500;
  }

  .product-compare-price {
    font-size: 1.5rem;
    color: var(--color-text-light);
    text-decoration: line-through;
  }

  /* Variant Pickers */
  .variant-selector {
    margin-bottom: 2rem;
  }

  .variant-label {
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 0.75rem;
    display: block;
  }

  .variant-options {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .variant-option {
    padding: 0.75rem 1.5rem;
    border: 1px solid var(--color-blush);
    background: var(--color-white);
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 0.9rem;
  }

  .variant-option:hover {
    border-color: var(--color-champagne);
  }

  .variant-option.selected {
    background: var(--color-champagne);
    color: var(--color-white);
    border-color: var(--color-champagne);
  }

  .variant-option.disabled {
    opacity: 0.4;
    cursor: not-allowed;
    text-decoration: line-through;
  }

  /* Color Swatches */
  .color-swatch {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 2px solid var(--color-white);
    box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .color-swatch:hover {
    transform: scale(1.1);
  }

  .color-swatch.selected {
    box-shadow: 0 0 0 2px var(--color-champagne);
  }

  /* Quantity Selector */
  .quantity-selector {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .quantity-input {
    width: 100px;
    padding: 0.75rem;
    text-align: center;
    border: 1px solid var(--color-blush);
    font-size: 1rem;
  }

  /* Buy Buttons */
  .buy-buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .btn-add-to-cart {
    width: 100%;
    padding: 1.25rem 2rem;
    background: var(--color-champagne);
    color: var(--color-white);
    border: none;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn-add-to-cart:hover {
    background: var(--color-text);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.15);
  }

  /* Description */
  .product-description {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-blush);
  }

  .product-description h3 {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    margin-bottom: 1rem;
  }

  /* Accordion */
  .product-accordion {
    margin-top: 1.5rem;
  }

  .accordion-item {
    border: 1px solid var(--color-blush);
    border-radius: 4px;
    margin-bottom: 0.5rem;
  }

  .accordion-header {
    padding: 1rem 1.5rem;
    background: var(--color-white);
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: 500;
  }

  .accordion-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .accordion-content.open {
    max-height: 500px;
  }

  .accordion-body {
    padding: 1.5rem;
    background: var(--color-cream-dark);
  }

  @media (max-width: 968px) {
    .product-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .product-gallery {
      position: static;
    }
  }
{% endstyle %}

<section class="product-template-section">
  <div class="product-container">
    <!-- Product Gallery -->
    <div class="product-gallery">
      <div class="main-image-wrapper">
        {% if product.featured_image %}
          {{
            product.featured_image
            | image_url: width: 800
            | image_tag: class: 'main-image', id: 'main-product-image'
          }}
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'main-image' }}
        {% endif %}
      </div>

      {% if product.media.size > 1 %}
        <div class="thumbnail-nav">
          {% for media in product.media limit: 4 %}
            <div class="thumbnail {% if forloop.first %}active{% endif %}"
                 data-image-id="{{ media.id }}">
              {{
                media
                | image_url: width: 200
                | image_tag: loading: 'lazy'
              }}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <!-- Product Info -->
    <div class="product-info" data-section-id="{{ section.id }}">
      {% assign on_sale = false %}
      {% if product.compare_at_price > product.price %}
        {% assign on_sale = true %}
      {% endif %}

      <div class="product-badges">
        {% if on_sale %}
          <span class="badge badge-sale">Sale</span>
        {% endif %}
        {% if product.tags contains 'New' %}
          <span class="badge badge-new">New</span>
        {% endif %}
      </div>

      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'title' %}
            <h1 class="product-title" {{ block.shopify_attributes }}>{{ product.title }}</h1>

          {% when 'price' %}
            <div class="product-price-area" {{ block.shopify_attributes }}>
              <span class="product-price">{{ product.price | money }}</span>
              {% if on_sale %}
                <span class="product-compare-price">{{ product.compare_at_price | money }}</span>
              {% endif %}
            </div>

          {% when 'variant_picker' %}
            {% for option in product.options_with_values %}
              <div class="variant-selector" {{ block.shopify_attributes }}>
                <label class="variant-label">{{ option.name }}</label>

                {% if block.settings.picker_type == 'button' %}
                  <div class="variant-options" data-option-index="{{ forloop.index }}">
                    {% for value in option.values %}
                      <button
                        type="button"
                        class="variant-option {% if option.selected_value == value %}selected{% endif %}"
                        data-value="{{ value }}"
                        data-option-index="{{ forloop.index }}">
                        {{ value }}
                      </button>
                    {% endfor %}
                  </div>
                {% endif %}
              </div>
            {% endfor %}

          {% when 'quantity' %}
            <div class="quantity-selector" {{ block.shopify_attributes }}>
              <label class="variant-label">Quantity</label>
              <input
                type="number"
                name="quantity"
                value="1"
                min="1"
                class="quantity-input">
            </div>

          {% when 'buy_buttons' %}
            <div class="buy-buttons" {{ block.shopify_attributes }}>
              {% form 'product', product %}
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                <button
                  type="submit"
                  name="add"
                  class="btn-add-to-cart {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}"
                  {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
                  {% if product.selected_or_first_available_variant.available %}
                    Add to Bag
                  {% else %}
                    Sold Out
                  {% endif %}
                </button>
              {% endform %}
            </div>

          {% when 'description' %}
            <div class="product-description" {{ block.shopify_attributes }}>
              <h3>Description</h3>
              <div class="description-content">
                {{ product.description }}
              </div>
            </div>

          {% when 'accordion' %}
            <div class="product-accordion" {{ block.shopify_attributes }}>
              <div class="accordion-item">
                <div class="accordion-header" data-accordion-trigger>
                  {{ block.settings.heading }}
                  <span>+</span>
                </div>
                <div class="accordion-content">
                  <div class="accordion-body">
                    {{ block.settings.content }}
                  </div>
                </div>
              </div>
            </div>
        {% endcase %}
      {% endfor %}
    </div>
  </div>
</section>

{% javascript %}
document.addEventListener('DOMContentLoaded', function() {
  // Thumbnail gallery
  const thumbnails = document.querySelectorAll('.thumbnail');
  const mainImage = document.getElementById('main-product-image');

  thumbnails.forEach(thumbnail => {
    thumbnail.addEventListener('click', function() {
      thumbnails.forEach(t => t.classList.remove('active'));
      this.classList.add('active');

      const imageSrc = this.querySelector('img').src;
      mainImage.src = imageSrc.replace('_200x', '_800x');
    });
  });

  // Accordion
  const accordionTriggers = document.querySelectorAll('[data-accordion-trigger]');

  accordionTriggers.forEach(trigger => {
    trigger.addEventListener('click', function() {
      const content = this.nextElementSibling;
      const isOpen = content.classList.contains('open');

      // Close all accordions
      document.querySelectorAll('.accordion-content').forEach(c => {
        c.classList.remove('open');
      });

      // Open clicked one if it was closed
      if (!isOpen) {
        content.classList.add('open');
      }
    });
  });

  // Variant selection
  const variantOptions = document.querySelectorAll('.variant-option');

  variantOptions.forEach(option => {
    option.addEventListener('click', function() {
      const optionIndex = this.dataset.optionIndex;
      const value = this.dataset.value;

      // Update selected state
      this.parentElement.querySelectorAll('.variant-option').forEach(o => {
        o.classList.remove('selected');
      });
      this.classList.add('selected');

      // Find and select the variant
      const select = document.querySelector(`select[data-option="${optionIndex}"]`);
      if (select) {
        select.value = value;
        select.dispatchEvent(new Event('change'));
      }
    });
  });
});
{% endjavascript %}
