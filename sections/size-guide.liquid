  .measurement-details h4 {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    margin: 0 0 0.5rem 0;
    color: var(--color-text);
  }

  .measurement-details p {
    color: var(--color-text-light);
    line-height: 1.6;
    margin: 0;
  }

  .size-help-cta {
    text-align: center;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-blush-light);
  }

  .size-help-cta p {
    font-size: 1.1rem;
