    }

    .size-guide-title {
      font-size: 1.5rem;
    }

    .size-guide-tabs {
      padding: 1rem;
    }

    .size-guide-body {
      padding: 1rem;
    }

    .size-chart-table-wrapper {
      font-size: 0.8rem;
    }

    .size-chart-table th,
    .size-chart-table td {
      padding: 0.75rem 0.5rem;
    }

    .measurement-item {
      flex-direction: column;
      text-align: center;
      padding: 1rem;
    }

    .measurement-icon {
