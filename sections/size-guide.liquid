    border: none;
    border-bottom: 2px solid transparent;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-light);
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .size-tab:hover {
    color: var(--color-champagne);
  }

  .size-tab.active {
    color: var(--color-champagne);
    border-bottom-color: var(--color-champagne);
  }

